# 武当内容创作系统 v3.0 - 环境变量模板
# 复制此文件为 .env 并填入实际值
# 注意: .env 文件包含敏感信息，请勿提交到版本控制

# 基础配置
NODE_ENV=development
PORT=8080

# 数据库
DATABASE_URL=postgresql://wudang:wudang123@localhost:5432/wudang_cms

# Redis
REDIS_URL=redis://localhost:6379

# JWT (请修改)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=wudang-cms
MINIO_USE_SSL=false

# ============================================
# 第三方 API 密钥 (请填入实际值)
# ============================================

# 火山引擎 Seedance API (AI视频生成)
SEEDANCE_API_KEY=your-seedance-api-key

# Qveris API (国内热点追踪)
QVERIS_API_KEY=your-qveris-api-key

# TikAPI (海外热点追踪)
TIKAPI_KEY=your-tikapi-key

# 阿里百炼 LLM API (AI预测)
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# 飞书Webhook (可选)
# FEISHU_WEBHOOK=your-feishu-webhook-url

# 日志
LOG_LEVEL=info
